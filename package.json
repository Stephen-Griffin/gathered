{
  "name": "gathered",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:reset": "dev-db reset && dev-db init && bun run db:migrate",
    "db:seed": "bun run scripts/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint .",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.12",
    "drizzle-orm": "^0.45.2",
    "next": "latest",
    "postgres": "^3.4.9",
    "react": "latest",
    "react-dom": "latest",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "latest",
    "prettier": "latest",
    "tailwindcss": "latest",
    "typescript": "latest",
    "vitest": "^4.1.10"
  },
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
