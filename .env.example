# Copy this file to .env for local development.
# Keep real secrets out of git.
NEXT_TELEMETRY_DISABLED=1

# Local Postgres connection. `dev-db init` prints this value.
DATABASE_URL=postgres://localhost:54330/gathered

# Clerk auth. Use values from a local Clerk application.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional: Clerk user id that receives local seed data.
SEED_CLERK_USER_ID=

# Shopping provider flow is link-out only in Sprint 1.
SHOPPING_PROVIDER_MODE=links-only

# Optional link defaults for local testing. Leave commented unless overriding.
# TARGET_SEARCH_BASE_URL=https://www.target.com/s
# AMAZON_SEARCH_BASE_URL=https://www.amazon.com/s

# Do not add retailer API keys, passwords, cookies, cart tokens, or fake
# credentials until an approved Amazon or Target program confirms exact names.
# AMAZON_ASSOCIATES_TAG is optional and should stay unset until program approval
# and affiliate disclosure requirements are ready.
# AMAZON_ASSOCIATES_TAG=
